{% extends 'front/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}

<section class="hero-section py-5">
    <div class="container text-center text-white">
        <h1 class="fw-bold"><i class="bi bi-building me-2"></i>Établissements</h1>
        <p class="lead opacity-75">Explorez les établissements partenaires de SchoolPrepar</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
        {% for etab in etablissements %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width:52px;height:52px;background:#4f46e5;color:white;font-weight:700;font-size:.85rem;flex-shrink:0;">
                                {{ etab.sigle ? etab.sigle|slice(0,4) : etab.nom|slice(0,4) }}
                            </div>
                            <div>
                                <h5 class="mb-0 fw-bold">{{ etab.nom }}</h5>
                                <small class="text-muted"><i class="bi bi-geo-alt-fill text-danger me-1"></i>{{ etab.ville }}</small>
                                {% if etab.type %}<br><span class="badge bg-light text-dark border mt-1">{{ etab.type }}</span>{% endif %}
                            </div>
                        </div>
                        <p class="text-muted small mb-3">{{ etab.description|default('')|slice(0,100) }}{% if etab.description|length > 100 %}…{% endif %}</p>
                        <div class="mb-2">
                            {% for f in etab.filieres %}
                                <span class="badge me-1 mb-1" style="background:#e0e7ff;color:#4f46e5;">{{ f.nom }}</span>
                            {% endfor %}
                        </div>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-4 px-4">
                        {% if etab.email %}
                            <a href="mailto:{{ etab.email }}" class="btn btn-outline-primary w-100">
                                <i class="bi bi-envelope me-1"></i>Contacter
                            </a>
                        {% else %}
                            <button class="btn btn-outline-secondary w-100" disabled>Infos à venir</button>
                        {% endif %}
                    </div>
                </div>
            </div>
        {% else %}
            <div class="col-12 text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">Aucun établissement disponible pour le moment.</p>
            </div>
        {% endfor %}
        </div>
    </div>
</section>
{% endblock %}
