{% extends 'front/base.html.twig' %}

{% block title %}{{ page_title }}{% endblock %}

{% block body %}

<section class="py-4" style="background:linear-gradient(135deg,#1e1b4b,#4f46e5);color:white;">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="{{ path('home') }}" class="text-light opacity-75">Accueil</a></li>
                <li class="breadcrumb-item active text-white">Établissements</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-1"><i class="bi bi-building-fill me-2"></i>Établissements Partenaires</h1>
        <p class="mb-0" style="color:#c7d2fe;">{{ etablissements|length }} établissement(s) référencés</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            {% for e in etablissements %}
            <div class="col-md-6">
                <div class="card h-100 p-1">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-start mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3 flex-shrink-0"
                                 style="width:55px;height:55px;background:#e0e7ff;font-size:1.3rem;font-weight:700;color:#4f46e5;">
                                {{ e.sigle|first }}
                            </div>
                            <div>
                                <h5 class="fw-bold mb-1">{{ e.nom }}</h5>
                                <span class="text-muted small">
                                    <i class="bi bi-geo-alt me-1"></i>{{ e.ville }}
                                    &nbsp;·&nbsp;
                                    <i class="bi bi-tag me-1"></i>{{ e.type }}
                                </span>
                            </div>
                        </div>

                        {% if e.filieres is defined and e.filieres|length > 0 %}
                        <div>
                            <small class="text-muted fw-semibold">Filières proposées :</small>
                            <div class="d-flex flex-wrap gap-1 mt-1">
                                {% for f in e.filieres %}
                                <span class="badge-filiere">{{ f }}</span>
                                {% endfor %}
                            </div>
                        </div>
                        {% endif %}
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 px-4">
                        <a href="{{ path('filieres') }}" class="btn btn-outline-primary btn-sm">
                            <i class="bi bi-book me-1"></i>Voir les filières
                        </a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center py-5">
                <i class="bi bi-building fs-1 text-muted"></i>
                <p class="text-muted mt-2">Aucun établissement disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
