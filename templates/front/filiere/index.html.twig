{% extends 'front/base.html.twig' %}

{% block title %}{{ page_title }}{% endblock %}

{% block body %}

<section class="py-4" style="background:linear-gradient(135deg,#1e1b4b,#4f46e5);color:white;">
    <div class="container">
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb mb-2">
                <li class="breadcrumb-item"><a href="{{ path('home') }}" class="text-light opacity-75">Accueil</a></li>
                <li class="breadcrumb-item active text-white">Filières</li>
            </ol>
        </nav>
        <h1 class="fw-bold mb-1"><i class="bi bi-book-fill me-2"></i>Nos Filières</h1>
        <p class="mb-0" style="color:#c7d2fe;">{{ filieres|length }} filière(s) disponibles</p>
    </div>
</section>

<section class="py-5">
    <div class="container">
        <div class="row g-4">
            {% for f in filieres %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 p-1">
                    <div class="card-body p-4">
                        <div class="d-flex align-items-center mb-3">
                            <div class="rounded-circle d-flex align-items-center justify-content-center me-3"
                                 style="width:50px;height:50px;background:#e0e7ff;">
                                <i class="bi bi-laptop fs-4" style="color:#4f46e5;"></i>
                            </div>
                            <div>
                                <h5 class="fw-bold mb-0">{{ f.nom }}</h5>
                                <span class="badge-filiere">{{ f.niveau }}</span>
                            </div>
                        </div>
                        <p class="text-muted small">{{ f.description }}</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 pb-3 px-4">
                        <a href="{{ path('filiere_show', {'id': f.id}) }}" class="btn btn-primary btn-sm w-100">
                            <i class="bi bi-arrow-right-circle me-1"></i>Voir les détails
                        </a>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="col-12 text-center py-5">
                <i class="bi bi-inbox fs-1 text-muted"></i>
                <p class="text-muted mt-2">Aucune filière disponible pour le moment.</p>
            </div>
            {% endfor %}
        </div>
    </div>
</section>

{% endblock %}
