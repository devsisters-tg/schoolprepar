<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}SchoolPrepar{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --sp-primary: #4f46e5; --sp-dark: #1e1b4b; }
        body { font-family: 'Segoe UI', sans-serif; background-color: #f8f9fa; }
        .navbar-brand span { color: #a5b4fc; }
        .navbar { background-color: var(--sp-dark) !important; }
        .hero-section { background: linear-gradient(135deg, var(--sp-dark) 0%, var(--sp-primary) 100%); color: white; padding: 80px 0; }
        .card { border: none; border-radius: 12px; box-shadow: 0 2px 15px rgba(0,0,0,.08); transition: transform .2s; }
        .card:hover { transform: translateY(-4px); }
        .stat-card { background: white; border-radius: 12px; padding: 24px; text-align: center; }
        .stat-number { font-size: 2.5rem; font-weight: 700; color: var(--sp-primary); }
        .badge-filiere { background-color: #e0e7ff; color: var(--sp-primary); padding: 4px 10px; border-radius: 20px; font-size: .8rem; font-weight: 600; }
        footer { background-color: var(--sp-dark); color: #a5b4fc; }
        .btn-primary { background-color: var(--sp-primary); border-color: var(--sp-primary); }
        .btn-primary:hover { background-color: #4338ca; border-color: #4338ca; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

{% include 'front/partials/nav.html.twig' %}

{% block body %}{% endblock %}

{% include 'front/partials/footer.html.twig' %}

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>
