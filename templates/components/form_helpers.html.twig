{% macro field(field, wrapper_class='mb-3') %}
<div class="{{ wrapper_class }}">
    {{ form_label(field, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
    {{ form_widget(field, {attr: {class: field.vars.attr.class ?? 'form-control'}}) }}
    {% if form_errors(field) %}
        <div class="text-danger small mt-1">
            <i class="bi bi-exclamation-circle me-1"></i>{{ form_errors(field) }}
        </div>
    {% endif %}
</div>
{% endmacro %}
