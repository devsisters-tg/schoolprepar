{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('admin_etablissements_index') }}" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h4 class="mb-0 fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>{{ page_title }}</h4>
    </div>
    <div class="card shadow-sm" style="max-width:700px">
        <div class="card-body p-4">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            <div class="mb-3">{{ form_label(form.nom) }}{{ form_widget(form.nom) }}</div>
            <div class="row">
                <div class="col-md-4 mb-3">{{ form_label(form.sigle) }}{{ form_widget(form.sigle) }}</div>
                <div class="col-md-4 mb-3">{{ form_label(form.ville) }}{{ form_widget(form.ville) }}</div>
                <div class="col-md-4 mb-3">{{ form_label(form.type) }}{{ form_widget(form.type) }}</div>
            </div>
            <div class="mb-3">{{ form_label(form.description) }}{{ form_widget(form.description) }}</div>
            <div class="row">
                <div class="col-md-6 mb-3">{{ form_label(form.email) }}{{ form_widget(form.email) }}</div>
                <div class="col-md-6 mb-3">{{ form_label(form.telephone) }}{{ form_widget(form.telephone) }}</div>
            </div>
            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-warning text-white"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
                <a href="{{ path('admin_etablissements_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
