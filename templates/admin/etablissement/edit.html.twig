{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('admin_etablissements_index') }}" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h4 class="mb-0 fw-bold">
            {% if 'edit' == 'new' %}
                <i class="bi bi-plus-circle me-2 text-primary"></i>
            {% else %}
                <i class="bi bi-pencil me-2 text-warning"></i>
            {% endif %}
            {{ page_title }}
        </h4>
    </div>
    <div class="card shadow-sm" style="max-width:700px">
        <div class="card-body p-4">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}

            <div class="mb-3">
                {{ form_label(form.nom, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(form.nom) }}
                {% if form_errors(form.nom) %}
                    <div class="text-danger small mt-1"><i class="bi bi-exclamation-circle me-1"></i>{{ form_errors(form.nom) }}</div>
                {% endif %}
            </div>

            <div class="row">
                <div class="col-md-4 mb-3">
                    {{ form_label(form.sigle, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.sigle) }}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(form.ville, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.ville) }}
                    {% if form_errors(form.ville) %}
                        <div class="text-danger small mt-1"><i class="bi bi-exclamation-circle me-1"></i>{{ form_errors(form.ville) }}</div>
                    {% endif %}
                </div>
                <div class="col-md-4 mb-3">
                    {{ form_label(form.type, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.type) }}
                </div>
            </div>

            <div class="mb-3">
                {{ form_label(form.description, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                {{ form_widget(form.description) }}
            </div>

            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.email, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.email) }}
                    {% if form_errors(form.email) %}
                        <div class="text-danger small mt-1"><i class="bi bi-exclamation-circle me-1"></i>{{ form_errors(form.email) }}</div>
                    {% endif %}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.telephone, null, {label_attr: {class: 'form-label fw-semibold'}}) }}
                    {{ form_widget(form.telephone) }}
                </div>
            </div>

            <div class="d-flex gap-2 mt-3">
                <button type="submit" class="btn btn-{% if 'edit' == 'new' %}primary{% else %}warning text-white{% endif %}">
                    <i class="bi bi-check-lg me-1"></i>Enregistrer
                </button>
                <a href="{{ path('admin_etablissements_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
