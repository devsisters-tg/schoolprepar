{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}
<div class="container-fluid py-4">

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                {{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="bi bi-building me-2 text-primary"></i>{{ page_title }}</h4>
            <small class="text-muted">{{ etablissements|length }} établissement(s) enregistré(s)</small>
        </div>
        <a href="{{ path('admin_etablissements_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nouvel établissement
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Sigle</th>
                        <th>Ville</th>
                        <th>Type</th>
                        <th>Filières</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for etab in etablissements %}
                    <tr>
                        <td class="text-muted">{{ etab.id }}</td>
                        <td class="fw-semibold">{{ etab.nom }}</td>
                        <td>{{ etab.sigle ?? '—' }}</td>
                        <td><i class="bi bi-geo-alt text-danger"></i> {{ etab.ville }}</td>
                        <td>{{ etab.type ?? '—' }}</td>
                        <td>
                            {% for f in etab.filieres %}
                                <span class="badge bg-light text-dark border">{{ f.nom }}</span>
                            {% else %}<span class="text-muted">—</span>{% endfor %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('admin_etablissements_show', {id: etab.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('admin_etablissements_edit', {id: etab.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('admin_etablissements_delete', {id: etab.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cet établissement ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ etab.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="7" class="text-center text-muted py-4">Aucun établissement enregistré.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
