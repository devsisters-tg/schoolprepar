{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}
<div class="container-fluid py-4">

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                {{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="bi bi-calendar-event me-2 text-primary"></i>{{ page_title }}</h4>
            <small class="text-muted">{{ evenements|length }} événement(s) enregistré(s)</small>
        </div>
        <a href="{{ path('admin_evenements_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nouvel événement
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Titre</th>
                        <th>Type</th>
                        <th>Date</th>
                        <th>Lieu</th>
                        <th>Filière</th>
                        <th>Établissement</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for ev in evenements %}
                    <tr>
                        <td class="text-muted">{{ ev.id }}</td>
                        <td class="fw-semibold">{{ ev.titre }}</td>
                        <td>{% if ev.type %}<span class="badge bg-info text-dark">{{ ev.type }}</span>{% else %}—{% endif %}</td>
                        <td>{{ ev.dateEvenement|date('d/m/Y H:i') }}</td>
                        <td>{{ ev.lieu ?? '—' }}</td>
                        <td>{{ ev.filiere ? ev.filiere.nom : '—' }}</td>
                        <td>{{ ev.etablissement ? ev.etablissement.nom : '—' }}</td>
                        <td class="text-end">
                            <a href="{{ path('admin_evenements_show', {id: ev.id}) }}" class="btn btn-sm btn-outline-secondary"><i class="bi bi-eye"></i></a>
                            <a href="{{ path('admin_evenements_edit', {id: ev.id}) }}" class="btn btn-sm btn-outline-primary"><i class="bi bi-pencil"></i></a>
                            <form method="post" action="{{ path('admin_evenements_delete', {id: ev.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cet événement ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ev.id) }}">
                                <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="8" class="text-center text-muted py-4">Aucun événement enregistré.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
