<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin — SchoolPrepar{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root { --admin-sidebar: #1e1b4b; --admin-primary: #4f46e5; }
        body { font-family: 'Segoe UI', sans-serif; background:#f1f5f9; }
        #sidebar {
            width: 250px; min-height: 100vh;
            background: var(--admin-sidebar);
            position: fixed; top:0; left:0; z-index:100;
            display:flex; flex-direction:column;
        }
        #sidebar .sidebar-brand {
            padding: 24px 20px;
            border-bottom: 1px solid rgba(255,255,255,.1);
            color: white; font-size: 1.2rem; font-weight: 700;
        }
        #sidebar .sidebar-brand span { color: #a5b4fc; }
        #sidebar .nav-link {
            color: #a5b4fc; padding: 12px 20px;
            border-radius: 8px; margin: 2px 10px;
            font-size: .9rem; transition: all .2s;
        }
        #sidebar .nav-link:hover, #sidebar .nav-link.active {
            background: rgba(255,255,255,.1); color: white;
        }
        #sidebar .nav-link i { width: 20px; }
        #sidebar .nav-section {
            padding: 16px 20px 4px;
            font-size: .7rem; font-weight: 700;
            text-transform: uppercase; letter-spacing: 1px; color: #6366f1;
        }
        #main-content { margin-left: 250px; min-height: 100vh; }
        #topbar {
            background: white; border-bottom: 1px solid #e2e8f0;
            padding: 14px 24px;
            display: flex; align-items:center; justify-content:space-between;
        }
        .page-content { padding: 24px; }
        .card { border:none; border-radius:12px; box-shadow:0 1px 10px rgba(0,0,0,.07); }
        .table th { font-size:.8rem; text-transform:uppercase; letter-spacing:.5px; color:#64748b; font-weight:600; }
        .btn-primary { background:var(--admin-primary); border-color:var(--admin-primary); }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<div id="sidebar">
    <div class="sidebar-brand">
        <i class="bi bi-shield-lock-fill me-2"></i>School<span>Prepar</span>
        <div style="font-size:.7rem;color:#6b7280;font-weight:400;margin-top:2px;">Panneau d'administration</div>
    </div>

    <nav class="mt-3 flex-grow-1">
        <div class="nav-section">Principal</div>
        <a href="{{ path('admin_dashboard') }}" class="nav-link {{ app.request.pathInfo == '/admin' ? 'active' : '' }}">
            <i class="bi bi-speedometer2 me-2"></i>Dashboard
        </a>

        <div class="nav-section mt-2">Gestion</div>
        <a href="{{ path('admin_filieres_index') }}" class="nav-link {{ app.request.pathInfo starts with '/admin/filieres' ? 'active' : '' }}">
            <i class="bi bi-book me-2"></i>Filières
        </a>
        <a href="{{ path('admin_etablissements_index') }}" class="nav-link {{ app.request.pathInfo starts with '/admin/etablissements' ? 'active' : '' }}">
            <i class="bi bi-building me-2"></i>Établissements
        </a>
        <a href="{{ path('admin_evenements_index') }}" class="nav-link {{ app.request.pathInfo starts with '/admin/evenements' ? 'active' : '' }}">
            <i class="bi bi-calendar-event me-2"></i>Événements
        </a>
        <a href="{{ path('admin_users_index') }}" class="nav-link {{ app.request.pathInfo starts with '/admin/users' ? 'active' : '' }}">
            <i class="bi bi-people me-2"></i>Utilisateurs
        </a>

        <div class="nav-section mt-2">Navigation</div>
        <a href="{{ path('home') }}" class="nav-link">
            <i class="bi bi-globe me-2"></i>Voir le site
        </a>
        <a href="{{ path('app_logout') }}" class="nav-link" style="color:#f87171;">
            <i class="bi bi-box-arrow-right me-2"></i>Déconnexion
        </a>
    </nav>

    <div style="padding:16px 20px;border-top:1px solid rgba(255,255,255,.1);">
        <small style="color:#6b7280;">IT 232 — Symfony TP4</small>
    </div>
</div>

<div id="main-content">
    {% include 'admin/partials/nav.html.twig' %}

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show m-3 mb-0">
                <i class="bi bi-{{ type == 'success' ? 'check-circle' : 'exclamation-triangle' }} me-2"></i>
                {{ msg }}
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="page-content">
        {% block body %}{% endblock %}
    </div>
    {% include 'admin/partials/footer.html.twig' %}
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>