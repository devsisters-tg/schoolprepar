{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">{{ page_title }}</h4>
        <small class="text-muted">{{ users|length }} utilisateur{{ users|length > 1 ? 's' : '' }} enregistré{{ users|length > 1 ? 's' : '' }}</small>
    </div>
    <a href="{{ path('admin_users_new') }}" class="btn btn-primary">
        <i class="bi bi-plus-lg me-1"></i>Nouvel utilisateur
    </a>
</div>

{% for msg in app.flashes('success') %}
    <div class="alert alert-success alert-dismissible fade show">{{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button></div>
{% endfor %}

<div class="card">
    <div class="card-body p-0">
        <table class="table table-hover mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Nom complet</th>
                    <th>E-mail</th>
                    <th>Téléphone</th>
                    <th>Rôle</th>
                    <th>Statut</th>
                    <th>Créé le</th>
                    <th class="text-end">Actions</th>
                </tr>
            </thead>
            <tbody>
            {% for user in users %}
                <tr>
                    <td class="text-muted">{{ user.id }}</td>
                    <td class="fw-semibold">{{ user.nomComplet }}</td>
                    <td><a href="mailto:{{ user.email }}" class="text-decoration-none">{{ user.email }}</a></td>
                    <td>{{ user.telephone ?? '—' }}</td>
                    <td>
                        {% if user.role == 'ROLE_ADMIN' %}
                            <span class="badge bg-danger">Admin</span>
                        {% elseif user.role == 'ROLE_ETABLISSEMENT' %}
                            <span class="badge bg-warning text-dark">Établissement</span>
                        {% else %}
                            <span class="badge bg-primary">Étudiant</span>
                        {% endif %}
                    </td>
                    <td>
                        {% if user.actif %}
                            <span class="badge bg-success">Actif</span>
                        {% else %}
                            <span class="badge bg-secondary">Inactif</span>
                        {% endif %}
                    </td>
                    <td class="text-muted" style="font-size:.85rem;">{{ user.createdAt|date('d/m/Y') }}</td>
                    <td class="text-end">
                        <a href="{{ path('admin_users_show', {id: user.id}) }}" class="btn btn-sm btn-outline-secondary">
                            <i class="bi bi-eye"></i>
                        </a>
                        <a href="{{ path('admin_users_edit', {id: user.id}) }}" class="btn btn-sm btn-outline-primary">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <form method="post" action="{{ path('admin_users_delete', {id: user.id}) }}" class="d-inline"
                              onsubmit="return confirm('Supprimer cet utilisateur ?')">
                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ user.id) }}">
                            <button class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i></button>
                        </form>
                    </td>
                </tr>
            {% else %}
                <tr><td colspan="8" class="text-center py-4 text-muted">Aucun utilisateur enregistré.</td></tr>
            {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}
