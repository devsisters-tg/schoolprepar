{% extends 'admin/base.html.twig' %}
{% block title %}Dashboard — SchoolPrepar Admin{% endblock %}
{% block body %}
<div class="container-fluid py-4">

    <div class="mb-4">
        <h4 class="fw-bold mb-0"><i class="bi bi-speedometer2 me-2 text-primary"></i>Dashboard</h4>
        <small class="text-muted">Vue d'ensemble — SchoolPrepar</small>
    </div>

    <!-- Stats cards -->
    <div class="row g-4 mb-5">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    <div class="rounded-3 d-flex align-items-center justify-content-center"
                         style="width:64px;height:64px;background:#e0e7ff;">
                        <i class="bi bi-journals" style="font-size:1.8rem;color:#4f46e5;"></i>
                    </div>
                    <div>
                        <div style="font-size:2.2rem;font-weight:700;color:#4f46e5;line-height:1;">
                            {{ nb_filieres }}
                        </div>
                        <div class="text-muted">Filières enregistrées</div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a href="{{ path('admin_filieres_index') }}" class="btn btn-sm btn-outline-primary">
                        Gérer <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    <div class="rounded-3 d-flex align-items-center justify-content-center"
                         style="width:64px;height:64px;background:#dcfce7;">
                        <i class="bi bi-building" style="font-size:1.8rem;color:#16a34a;"></i>
                    </div>
                    <div>
                        <div style="font-size:2.2rem;font-weight:700;color:#16a34a;line-height:1;">
                            {{ nb_etablissements }}
                        </div>
                        <div class="text-muted">Établissements</div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a href="{{ path('admin_etablissements_index') }}" class="btn btn-sm btn-outline-success">
                        Gérer <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body d-flex align-items-center gap-4 p-4">
                    <div class="rounded-3 d-flex align-items-center justify-content-center"
                         style="width:64px;height:64px;background:#fef3c7;">
                        <i class="bi bi-calendar-event" style="font-size:1.8rem;color:#d97706;"></i>
                    </div>
                    <div>
                        <div style="font-size:2.2rem;font-weight:700;color:#d97706;line-height:1;">
                            {{ nb_evenements }}
                        </div>
                        <div class="text-muted">Événements</div>
                    </div>
                </div>
                <div class="card-footer bg-transparent border-0 pb-3 px-4">
                    <a href="{{ path('admin_evenements_index') }}" class="btn btn-sm btn-outline-warning">
                        Gérer <i class="bi bi-arrow-right ms-1"></i>
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Prochains événements -->
    {% if prochains_evts is defined and prochains_evts|length > 0 %}
    <div class="card shadow-sm">
        <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
            <h6 class="mb-0 fw-bold"><i class="bi bi-calendar-check text-primary me-2"></i>Prochains événements</h6>
            <a href="{{ path('admin_evenements_new') }}" class="btn btn-sm btn-primary">
                <i class="bi bi-plus me-1"></i>Ajouter
            </a>
        </div>
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Titre</th><th>Date</th><th>Lieu</th><th>Type</th>
                    </tr>
                </thead>
                <tbody>
                {% for ev in prochains_evts %}
                    <tr>
                        <td class="fw-semibold">{{ ev.titre }}</td>
                        <td>{{ ev.dateEvenement|date('d/m/Y') }}</td>
                        <td>{{ ev.lieu ?? '—' }}</td>
                        <td>{% if ev.type %}<span class="badge bg-info text-dark">{{ ev.type }}</span>{% else %}—{% endif %}</td>
                    </tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
