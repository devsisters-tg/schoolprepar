{% extends 'admin/base.html.twig' %}
{% block title %}{{ page_title }}{% endblock %}
{% block body %}
<div class="container-fluid py-4">
    <div class="d-flex align-items-center mb-4">
        <a href="{{ path('admin_filieres_index') }}" class="btn btn-outline-secondary me-3"><i class="bi bi-arrow-left"></i></a>
        <h4 class="mb-0 fw-bold"><i class="bi bi-pencil me-2 text-warning"></i>{{ page_title }}</h4>
    </div>
    <div class="card shadow-sm" style="max-width:700px">
        <div class="card-body p-4">
            {{ form_start(form, {attr: {novalidate: 'novalidate'}}) }}
            <div class="mb-3">
                {{ form_label(form.nom) }}
                {{ form_widget(form.nom) }}
            </div>
            <div class="row">
                <div class="col-md-6 mb-3">
                    {{ form_label(form.niveau) }}
                    {{ form_widget(form.niveau) }}
                </div>
                <div class="col-md-6 mb-3">
                    {{ form_label(form.duree) }}
                    {{ form_widget(form.duree) }}
                </div>
            </div>
            <div class="mb-3">
                {{ form_label(form.description) }}
                {{ form_widget(form.description) }}
            </div>
            <div class="mb-3">
                {{ form_label(form.debouches) }}
                {{ form_widget(form.debouches) }}
            </div>
            <div class="mb-3">
                <label class="form-label fw-semibold">Établissements proposant cette filière</label>
                <div class="border rounded p-3">
                    {{ form_widget(form.etablissements) }}
                </div>
            </div>
            <div class="d-flex gap-2 mt-4">
                <button type="submit" class="btn btn-warning text-white"><i class="bi bi-check-lg me-1"></i>Enregistrer</button>
                <a href="{{ path('admin_filieres_index') }}" class="btn btn-outline-secondary">Annuler</a>
            </div>
            {{ form_end(form) }}
        </div>
    </div>
</div>
{% endblock %}
