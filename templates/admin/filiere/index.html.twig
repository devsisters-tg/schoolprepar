{% extends 'admin/base.html.twig' %}

{% block title %}{{ page_title }}{% endblock %}

{% block body %}
<div class="container-fluid py-4">

    {% for type, messages in app.flashes %}
        {% for msg in messages %}
            <div class="alert alert-{{ type == 'success' ? 'success' : 'danger' }} alert-dismissible fade show">
                {{ msg }}<button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        {% endfor %}
    {% endfor %}

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="mb-0 fw-bold"><i class="bi bi-journals me-2 text-primary"></i>{{ page_title }}</h4>
            <small class="text-muted">{{ filieres|length }} filière(s) enregistrée(s)</small>
        </div>
        <a href="{{ path('admin_filieres_new') }}" class="btn btn-primary">
            <i class="bi bi-plus-lg me-1"></i> Nouvelle filière
        </a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>#</th>
                        <th>Nom</th>
                        <th>Niveau</th>
                        <th>Durée</th>
                        <th>Établissements</th>
                        <th class="text-end">Actions</th>
                    </tr>
                </thead>
                <tbody>
                {% for filiere in filieres %}
                    <tr>
                        <td class="text-muted">{{ filiere.id }}</td>
                        <td class="fw-semibold">{{ filiere.nom }}</td>
                        <td><span class="badge bg-indigo text-white" style="background:#4f46e5">{{ filiere.niveau }}</span></td>
                        <td>{{ filiere.duree ?? '—' }}</td>
                        <td>
                            {% for etab in filiere.etablissements %}
                                <span class="badge bg-light text-dark border">{{ etab.sigle ?? etab.nom }}</span>
                            {% else %}
                                <span class="text-muted">—</span>
                            {% endfor %}
                        </td>
                        <td class="text-end">
                            <a href="{{ path('admin_filieres_show', {id: filiere.id}) }}" class="btn btn-sm btn-outline-secondary" title="Voir">
                                <i class="bi bi-eye"></i>
                            </a>
                            <a href="{{ path('admin_filieres_edit', {id: filiere.id}) }}" class="btn btn-sm btn-outline-primary" title="Modifier">
                                <i class="bi bi-pencil"></i>
                            </a>
                            <form method="post" action="{{ path('admin_filieres_delete', {id: filiere.id}) }}" class="d-inline"
                                  onsubmit="return confirm('Supprimer cette filière ?')">
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ filiere.id) }}">
                                <button class="btn btn-sm btn-outline-danger" title="Supprimer"><i class="bi bi-trash"></i></button>
                            </form>
                        </td>
                    </tr>
                {% else %}
                    <tr><td colspan="6" class="text-center text-muted py-4">Aucune filière enregistrée.</td></tr>
                {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
